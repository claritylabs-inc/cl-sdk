name: Publish MCP Server

on:
  push:
    branches: [main]
    paths:
      - "mcp/**"
      - ".github/workflows/publish-mcp.yml"
  workflow_dispatch:

# Prevent concurrent releases
concurrency:
  group: publish-mcp
  cancel-in-progress: false

permissions:
  contents: write
  id-token: write

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
          persist-credentials: false

      - uses: actions/setup-node@v4
        with:
          node-version: "24"
          registry-url: "https://registry.npmjs.org"

      - name: Check if version already published
        id: check
        run: |
          cd mcp
          PACKAGE_VERSION=$(node -p "require('./package.json').version")
          echo "version=$PACKAGE_VERSION" >> $GITHUB_OUTPUT
          
          if npm view "@claritylabs/cl-sdk-mcp@$PACKAGE_VERSION" version 2>/dev/null; then
            echo "published=true" >> $GITHUB_OUTPUT
            echo "Version $PACKAGE_VERSION already published"
          else
            echo "published=false" >> $GITHUB_OUTPUT
            echo "Version $PACKAGE_VERSION needs to be published"
          fi

      - name: Install dependencies
        if: steps.check.outputs.published == 'false'
        working-directory: mcp
        run: npm install --no-audit --no-fund

      - name: Build docs bundle
        if: steps.check.outputs.published == 'false'
        working-directory: mcp
        run: npx tsx build-docs.ts

      - name: Delete higher historical MCP versions from npm
        if: steps.check.outputs.published == 'false'
        run: node scripts/prune-mcp-npm-history.mjs
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}

      - name: Publish to npm
        if: steps.check.outputs.published == 'false'
        id: npm_publish
        run: |
          cd mcp
          echo "Publishing version ${{ steps.check.outputs.version }} to npm..."
          npm publish --provenance --access public --tag latest
          echo "success=true" >> $GITHUB_OUTPUT
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}

      - name: Ensure GitHub tag for release
        if: steps.check.outputs.published == 'true' || steps.npm_publish.outputs.success == 'true'
        run: |
          VERSION="${{ steps.check.outputs.version }}"
          TAG="v$VERSION-mcp"
          if git ls-remote --exit-code --tags origin "refs/tags/$TAG" >/dev/null 2>&1; then
            echo "Tag $TAG already exists"
          else
            gh api "repos/${{ github.repository }}/git/refs" \
              -f ref="refs/tags/$TAG" \
              -f sha="${{ github.sha }}"
            echo "Created tag $TAG"
          fi
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Verify npm publication
        if: steps.check.outputs.published == 'true' || steps.npm_publish.outputs.success == 'true'
        run: |
          VERSION="${{ steps.check.outputs.version }}"
          echo "Verifying npm publication..."
          
          for i in 1 2 3; do
            if npm view "@claritylabs/cl-sdk-mcp@$VERSION" version 2>/dev/null; then
              echo "✓ npm package verified"
              break
            fi
            echo "Waiting for npm to propagate... (attempt $i/3)"
            sleep 5
          done

      - name: Notify on failure
        if: failure() && steps.check.outputs.published == 'false'
        run: |
          echo "::error::MCP package publish failed!"
          echo "Version: ${{ steps.check.outputs.version }}"
          echo "Check the logs above for details."
